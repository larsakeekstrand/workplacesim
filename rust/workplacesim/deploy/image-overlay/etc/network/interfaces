# /etc/network/interfaces — DHCP on eth0 and wlan0 so the Pi comes up
# networked on first boot without any post-flash configuration.
#
# WiFi SSID/PSK provisioning is NOT handled here. If you need wifi, edit
# /etc/wpa_supplicant/wpa_supplicant.conf on the boot partition (before
# flashing, or by remounting the SD on a second machine) with:
#
#   ctrl_interface=/var/run/wpa_supplicant
#   update_config=1
#   network={
#       ssid="YourSSID"
#       psk="YourPSK"
#   }
#
# Ethernet works out of the box.

auto lo
iface lo inet loopback

auto eth0
iface eth0 inet dhcp

auto wlan0
iface wlan0 inet dhcp
