{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/workplacesim/hook/workplacesim-hook.sh pretool",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/workplacesim/hook/workplacesim-hook.sh start",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/workplacesim/hook/workplacesim-hook.sh stop",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ]
  }
}
